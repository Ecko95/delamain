{
  "name": "codex-mcp-peers-server",
  "version": "0.1.0",
  "description": "MCP server and tmux-friendly dashboard for supervising headless Codex peers across repositories.",
  "type": "module",
  "private": false,
  "bin": {
    "codex-peers": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "server": "node dist/index.js server",
    "dashboard": "node dist/index.js dashboard",
    "mcp:restart": "bash scripts/restart-mcp.sh",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:frozen-gate": "vitest run src/frozen-gate"
  },
  "keywords": [
    "codex",
    "mcp",
    "tmux",
    "agents"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "0.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
