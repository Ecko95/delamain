{
  "name": "delamain",
  "version": "0.1.0",
  "description": "Multi-engine, multi-channel agent supervisor — spawns and integrates headless coding peers (Codex, Cursor, ...) in isolated git worktrees.",
  "type": "module",
  "private": false,
  "bin": {
    "delamain": "./dist/index.js",
    "codex-peers": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "server": "node dist/index.js server",
    "dashboard": "node dist/index.js dashboard",
    "mcp:restart": "bash scripts/restart-mcp.sh",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:frozen-gate": "vitest run src/frozen-gate",
    "test:frozen-eligibility": "vitest run src/frozen-eligibility"
  },
  "keywords": [
    "delamain",
    "codex",
    "cursor",
    "mcp",
    "tmux",
    "agents",
    "agent-supervisor",
    "git-worktree"
  ],
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "0.2.4",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
